# ─── Database ───────────────────────────────────
DATABASE_URL="postgresql://schoolos:schoolos_dev@localhost:5432/school_os"

# ─── Auth ───────────────────────────────────────
JWT_SECRET="change-me-in-production"

# ─── Web App (apps/web) ─────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXT_PUBLIC_AI_URL="http://localhost:8000"

# ─── Mobile App (apps/mobile) ───────────────────
EXPO_PUBLIC_API_URL="http://localhost:3000"

# ─── AI Microservice (services/ai) ──────────────
# Groq — recommended for testing (fast, generous free tier)
# Get key at: console.groq.com
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
DEFAULT_LLM="groq"

# Optional — only needed if you want GPT-4o or OpenAI embeddings for RAG
OPENAI_API_KEY=""
# Optional — only needed if you want Anthropic Claude
ANTHROPIC_API_KEY=""

# ─── Cache ──────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Storage (AWS S3) ───────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION="ap-south-1"

# ─── Email / SMS ────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
